{%- comment -%}
  EU Withdrawal — "Bouton de rétractation" app block.
  No server logic: opens the public withdrawal form (served by the App Proxy at
  /apps/retractation) in a modal popup. Styles/JS live in assets/ because app
  blocks disallow stylesheet/javascript Liquid tags.
{%- endcomment -%}

<div
  class="eu-wd-wrap"
  style="text-align: {{ block.settings.alignment }};"
  {{ block.shopify_attributes }}
>
  <button
    type="button"
    class="eu-wd-button"
    data-eu-wd-open
    style="background-color: {{ block.settings.bg_color }}; color: {{ block.settings.text_color }};"
  >
    {{ block.settings.label }}
  </button>
</div>

<div class="eu-wd-modal" data-eu-wd-modal hidden>
  <div class="eu-wd-overlay" data-eu-wd-close></div>
  <div class="eu-wd-dialog">
    <button class="eu-wd-x" type="button" data-eu-wd-close aria-label="Fermer">&times;</button>
    <iframe
      class="eu-wd-frame"
      title="{{ block.settings.label | escape }}"
      data-src="/apps/retractation"
      loading="lazy"
    ></iframe>
  </div>
</div>

{{ 'withdrawal-button.css' | asset_url | stylesheet_tag }}
<script src="{{ 'withdrawal-button.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "t:name",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "t:settings.label.label",
      "default": "Exercer mon droit de rétractation"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "t:settings.alignment.label",
      "options": [
        { "value": "left", "label": "t:settings.alignment.options.left" },
        { "value": "center", "label": "t:settings.alignment.options.center" },
        { "value": "right", "label": "t:settings.alignment.options.right" }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "t:settings.bg_color.label",
      "default": "#0f172a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:settings.text_color.label",
      "default": "#ffffff"
    }
  ]
}
{% endschema %}
