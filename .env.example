# ============================================================
# EU Withdrawal App — environment variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local`. All Supabase/Shopify secrets stay server-side.
# ============================================================

# --- Shopify (Partner Dashboard → your app) ---------------------------------
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# Comma-separated, e.g. read_orders,write_orders,read_customers
SHOPIFY_SCOPES=read_orders,write_orders,read_customers
# Public base URL of the deployed app (Vercel), no trailing slash
SHOPIFY_APP_URL=http://localhost:3000

# --- Supabase (EU region — Frankfurt) ---------------------------------------
# Server-side only. service_role bypasses RLS — NEVER expose to the client.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Public client (safe to expose). Must be NEXT_PUBLIC_ for the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Resend (transactional email) -------------------------------------------
RESEND_API_KEY=
# Verified sender, e.g. "EU Withdrawal <noreply@yourdomain.com>"
RESEND_FROM=

# --- App crypto -------------------------------------------------------------
# Generate with: openssl rand -base64 32
# Used to encrypt Shopify access tokens at rest (32 bytes, base64).
APP_ENCRYPTION_KEY=
